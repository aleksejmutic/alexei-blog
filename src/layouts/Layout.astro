---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>alexei's blog</title>
        <link rel="icon" type="image/png" href="/letter-a.png" />
    </head>
    <body class="bg-white text-gray-900 dark:bg-gray-900 dark:text-gray-100">
        <slot />
        <!-- Sticky Social Bar -->
        <div class="fixed bottom-0 left-0 w-full flex justify-center pb-4 z-50">
            <div
                class="bg-[#fdfaf4] border border-[#d9cfc0] rounded-full px-10 py-3 shadow-md flex gap-20 text-[#7c6f5a] text-lg"
            >
                <a
                    href="https://github.com/aleksejmutic"
                    target="_blank"
                    class="flex items-center gap-1 hover:text-[#3b3228] transition"
                >
                    <!-- GitHub Icon -->
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M12 .5C5.65.5.5 5.65.5 12c0 5.1 3.29 9.43 7.86 10.96.57.1.78-.25.78-.55v-2.15c-3.2.7-3.88-1.38-3.88-1.38-.52-1.33-1.28-1.68-1.28-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.67 1.24 3.32.95.1-.74.4-1.24.73-1.53-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.3 1.18-3.1-.12-.3-.51-1.5.11-3.12 0 0 .96-.31 3.15 1.18a10.9 10.9 0 012.87-.39c.97 0 1.95.13 2.87.39 2.19-1.5 3.15-1.18 3.15-1.18.62 1.62.23 2.82.11 3.12.73.8 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.68.41.36.77 1.08.77 2.18v3.23c0 .3.21.66.79.55A11.51 11.51 0 0023.5 12c0-6.35-5.15-11.5-11.5-11.5z"
                        ></path>
                    </svg>
                    GitHub
                </a>

                <a
                    href="https://www.linkedin.com/in/aleksej-muti%C4%87-aa0870304/"
                    target="_blank"
                    class="flex items-center gap-1 hover:text-[#3b3228] transition"
                >
                    <!-- LinkedIn Icon -->
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="w-5 h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M20.45 20.45h-3.55v-5.56c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.44-2.13 2.93v5.67H9.37V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.61 0 4.28 2.37 4.28 5.45v6.29zM5.34 7.43a2.06 2.06 0 110-4.12 2.06 2.06 0 010 4.12zM7.11 20.45H3.56V9h3.55v11.45z"
                        ></path>
                    </svg>
                    LinkedIn
                </a>
            </div>
        </div>
    </body>
</html>
