---
import Layout from "../layouts/PublicLayout.astro";
import { supabase } from "../lib/supabase";
import { formatDateNoYear } from "../lib/formatDate";

export const prerender = true;

type Post = {
  id: string;
  title: string;
  slug: string;
  content: string;
  description?: string | null;
  created_at: string;
  updated_at?: string;
  is_published: boolean;
};

const { data: posts } = await supabase
  .from("posts")
  .select("*")
  .eq("is_published", true)
  .order("created_at", { ascending: false })
  .returns<Post[]>();

const safePosts = posts ?? [];

const grouped = safePosts.reduce(
  (acc, post) => {
    const year = new Date(post.created_at).getFullYear();

    if (!acc[year]) acc[year] = [];
    acc[year].push(post);

    return acc;
  },
  {} as Record<number, Post[]>,
);
---

<Layout>
  <div class="min-h-screen bg-[#fdfaf4] text-[#3b3228] font-serif">
    <div class="max-w-3xl mx-auto px-6 pt-16 pb-24">
      <!-- HEADER -->
      <header class="mb-6 text-center">
        <h1 class="text-5xl font-bold tracking-tight">alexei's blog</h1>
        <p class="text-[#7c6f5a] text-3xl mt-5">
          Writing about code and software
        </p>
      </header>

      <!-- ABOUT -->
      <section class="mb-10 text-center">
        <p class="text-2xl text-[#3b3228] max-w-xl mx-auto leading-relaxed">
          I'm Aleksej, a Software Developer who digs into hardware, networking,
          security, and occasionally rants about how we write software. This is
          where I write about what I learn.
        </p>
      </section>

      <!-- SEARCH -->
      <div class="mb-5 relative">
        <input
          id="search"
          type="text"
          placeholder="Search posts..."
          class="w-full bg-white border border-[#d9cfc0] rounded-lg px-4 py-3 text-xl text-[#3b3228] font-serif focus:outline-none focus:ring-2 focus:ring-[#7c6f5a] pr-10"
        />
        <button
          id="clear"
          class="absolute right-3 top-1/2 -translate-y-1/2 text-[#7c6f5a] hover:text-[#3b3228] transition hidden text-2xl"
        >
          ×
        </button>
      </div>

      <!-- POSTS GROUPED BY YEAR -->
      <main class="space-y-14" id="posts-container">
        {
          Object.entries(grouped)
            .sort((a, b) => Number(b[0]) - Number(a[0]))
            .map(([year, posts]: [string, Post[]]) => {
              const y = Number(year);

              return (
                <div>
                  {/* YEAR HEADER */}
                  <h2 class="text-5xl font-bold text-[#3b3228] mb-3">{y}</h2>

                  <div class="space-y-4">
                    {posts.map((post) => (
                      <a
                        href={`/blog/${post.slug}`}
                        class="block px-4 py-3 bg-[#fdfaf4] border border-[#d9cfc0] rounded-lg shadow-sm hover:shadow-md transition"
                      >
                        <article class="flex items-center gap-6">
                          <time class="w-24 text-center text-xl text-[#7c6f5a] shrink-0">
                            {formatDateNoYear(post.created_at)}
                          </time>

                          <div class="flex-1 min-w-0">
                            <h2 class="text-2xl font-semibold text-[#3b3228] leading-tight">
                              {post.title}
                            </h2>

                            {post.description && (
                              <p class="text-lg text-[#7c6f5a] mt-1 line-clamp-1 leading-snug">
                                {post.description}
                              </p>
                            )}
                          </div>
                        </article>
                      </a>
                    ))}
                  </div>
                </div>
              );
            })
        }
      </main>
    </div>
  </div>
  <script>
    const search = document.getElementById("search") as HTMLInputElement;
    const clear = document.getElementById("clear") as HTMLButtonElement;
    const posts = document.querySelectorAll("a[href^='/blog/']");
    const yearGroups = document.querySelectorAll("#posts-container > div");

    search.addEventListener("input", () => {
      const query = search.value.toLowerCase().trim();

      // Show/hide clear button
      clear.classList.toggle("hidden", query === "");

      posts.forEach((post) => {
        const title =
          post.querySelector("h2")?.textContent?.toLowerCase() ?? "";
        const matches = title.includes(query);
        (post as HTMLElement).style.display = matches ? "" : "none";
      });

      // Hide year groups with no visible posts
      yearGroups.forEach((group) => {
        const visiblePosts = group.querySelectorAll(
          "a[href^='/blog/']:not([style*='display: none'])",
        );
        (group as HTMLElement).style.display =
          visiblePosts.length > 0 ? "" : "none";
      });
    });

    clear.addEventListener("click", () => {
      search.value = "";
      clear.classList.add("hidden");
      posts.forEach((post) => ((post as HTMLElement).style.display = ""));
      yearGroups.forEach(
        (group) => ((group as HTMLElement).style.display = ""),
      );
    });
  </script>
</Layout>
