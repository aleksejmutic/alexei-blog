---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <div
  class="min-h-screen bg-[#fdfaf4] text-[#3b3228] font-serif flex flex-col items-center justify-center"
>
<div class="text-center px-6">
            <img
                src="/setting.png"
                alt="Work in Progress"
                style="width: 150px; height: 150px; object-fit: contain;"
                class="mx-auto mb-6"
            />
            <h1 class="text-5xl font-bold mb-3">Work in Progress</h1>
            <p class="text-3xl text-[#7c6f5a] max-w-md mx-auto leading-relaxed">
                This article is still cooking. Check back soon!
            </p>

            <a
                href="/"
                class="inline-block mt-8 text-3xl text-[#7c6f5a] font-bold hover:text-[#3b3228] transition"
            >
                ← Back to all posts
            </a>
        </div>
    </div>
</Layout>
